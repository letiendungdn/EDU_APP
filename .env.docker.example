# Docker Compose — copy to .env and chỉnh nếu cần
POSTGRES_PASSWORD=nihongo
ENGLISH_POSTGRES_PASSWORD=english
# Stack Nihongo-only (mặc định): false — không cần postgres-english
# Full stack: docker compose --profile english up -d và đặt ENGLISH_ENABLED=true
ENGLISH_ENABLED=false
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
ADMIN_EMAIL=admin@nihongo.local
ADMIN_PASSWORD=admin123
# Nginx host port (tránh bind :80 — đổi nếu 8080 bị chiếm)
NGINX_HTTP_PORT=8080
ALLOWED_ORIGINS=http://localhost:8080,http://nihongo.localhost:8080,http://english.localhost:8080,http://localhost:5173,http://localhost:3001
NEXT_PUBLIC_SIGNALING_URL=http://localhost:3002
SIGNALING_CORS_ORIGIN=http://localhost:8080,http://localhost:5173,http://nihongo.localhost:8080
NEXT_PUBLIC_ENGLISH_APP_URL=http://english.localhost:8080
NEXT_PUBLIC_NIHONGO_APP_URL=http://nihongo.localhost:8080
