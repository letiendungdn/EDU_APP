{
  "name": "edu-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo học tiếng Nhật & tiếng Anh — micro frontends + microservices",
  "workspaces": [
    "apps/*",
    "services",
    "services/signaling-service",
    "packages/*"
  ],
  "scripts": {
    "dev:nihongo-web": "npm run dev -w @edu/nihongo-web",
    "dev:english-web": "npm run dev -w @edu/english-web",
    "dev:gateway": "npm run start:dev -w @edu/nihongo-services",
    "dev:content": "npm run start:content -w @edu/nihongo-services",
    "dev:exam": "npm run start:exam -w @edu/nihongo-services",
    "dev:signaling": "npm run start:dev -w @edu/signaling-service",
    "build:services": "npm run build:all -w @edu/nihongo-services",
    "build:nihongo-web": "npm run build -w @edu/nihongo-web",
    "build:english-web": "npm run build -w @edu/english-web",
    "docker:up": "docker compose --profile english up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:up:build": "docker compose --profile english up -d --build",
    "docker:up:infra": "docker compose up -d postgres-nihongo redis mongodb zookeeper kafka",
    "docker:up:infra:full": "docker compose --profile english up -d postgres-nihongo postgres-english redis mongodb zookeeper kafka",
    "docker:up:nihongo": "docker compose up -d postgres-nihongo redis mongodb zookeeper kafka content-service exam-service api-gateway nihongo-web nginx",
    "stripe": "stripe.cmd",
    "stripe:login": "stripe.cmd login",
    "stripe:listen": "stripe.cmd listen --forward-to localhost:3000/api/webhooks/stripe",
    "seed:vocab-images": "npm run seed:vocab-images -w @edu/nihongo-services",
    "prisma:generate": "npm run generate -w @edu/prisma-nihongo",
    "db:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File infra/backups/backup.ps1",
    "db:export-content": "powershell -NoProfile -ExecutionPolicy Bypass -File infra/postgres/export-content-seed.ps1",
    "media:download": "node packages/vocab-images/scripts/download-media.mjs",
    "media:sync": "node packages/vocab-images/scripts/sync-public.mjs",
    "media:setup": "npm run media:download && npm run media:sync && npm run seed:vocab-images"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
