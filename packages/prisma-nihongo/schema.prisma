generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  TEACHER
  ADMIN
}

enum JlptLevel {
  N5
  N4
  N3
  N2
  N1
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_IN_BLANK
  LISTENING
}

enum ContentType {
  VOCABULARY
  GRAMMAR
  KANJI
}

enum KanaScript {
  HIRAGANA
  KATAKANA
}

enum JlptSessionStatus {
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  UPCOMING
  PAST
}

// ─────────────────────────────────────────────
// Content
// ─────────────────────────────────────────────

model Lesson {
  id           Int          @id @default(autoincrement())
  lessonNumber Int          @unique
  title        String?
  description  String?
  jlptLevel    JlptLevel?
  thumbnailUrl String?
  sortOrder    Int          @default(0)
  vocabularies Vocabulary[]
  grammars     Grammar[]
  exercises    Exercise[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([jlptLevel, sortOrder])
}

model Vocabulary {
  id            Int                @id @default(autoincrement())
  kanji         String?
  kana          String
  romaji        String
  meaning       String
  meaningEn     String?
  partOfSpeech  String?
  jlptLevel     JlptLevel?
  pitchAccent   String?
  audioUrl      String?
  imageUrl      String?
  frequencyRank Int?
  sortOrder     Int                @default(0)
  lessonId      Int
  lesson        Lesson             @relation(fields: [lessonId], references: [id])
  dictations    DictationAttempt[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([lessonId, sortOrder])
  @@index([jlptLevel])
}

model Grammar {
  id             Int        @id @default(autoincrement())
  pattern        String
  meaning        String
  explanation    String?
  jlptLevel      JlptLevel?
  formalityLevel String?
  sortOrder      Int        @default(0)
  lessonId       Int
  lesson         Lesson     @relation(fields: [lessonId], references: [id])
  examples       Example[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([lessonId, sortOrder])
  @@index([jlptLevel])
}

model Example {
  id        Int     @id @default(autoincrement())
  jp        String
  romaji    String
  en        String?
  vi        String?
  audioUrl  String?
  sortOrder Int     @default(0)
  grammarId Int
  grammar   Grammar @relation(fields: [grammarId], references: [id], onDelete: Cascade)
}

model Exercise {
  id          Int              @id @default(autoincrement())
  type        ExerciseType
  question    String
  answer      String
  explanation String?
  audioUrl    String?
  difficulty  Int              @default(1)
  sortOrder   Int              @default(0)
  lessonId    Int
  lesson      Lesson           @relation(fields: [lessonId], references: [id])
  options     ExerciseOption[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([lessonId, sortOrder])
}

model ExerciseOption {
  id         Int      @id @default(autoincrement())
  exerciseId Int
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)

  @@index([exerciseId, sortOrder])
}

// ─────────────────────────────────────────────
// Kana charts
// ─────────────────────────────────────────────

model KanaSection {
  id        Int        @id @default(autoincrement())
  script    KanaScript
  slug      String
  title     String
  subtitle  String?
  columns   Int        @default(5)
  sortOrder Int        @default(0)
  cells     KanaCell[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([script, slug])
  @@index([script, sortOrder])
}

model KanaCell {
  id        Int         @id @default(autoincrement())
  sectionId Int
  section   KanaSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  rowIndex  Int
  colIndex  Int
  kana      String      @default("")
  romaji    String      @default("")

  @@unique([sectionId, rowIndex, colIndex])
  @@index([sectionId])
}

// ─────────────────────────────────────────────
// Japanese counters
// ─────────────────────────────────────────────

model CounterCategory {
  id        Int           @id @default(autoincrement())
  slug      String        @unique
  label     String
  hint      String
  sortOrder Int           @default(0)
  items     CounterItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model CounterItem {
  id            Int             @id @default(autoincrement())
  categoryId    Int
  category      CounterCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  displayNumber String
  kanji         String?
  kana          String
  romaji        String
  meaningVi     String
  sortOrder     Int             @default(0)

  @@index([categoryId, sortOrder])
}

// ─────────────────────────────────────────────
// Japanese pronunciation rules (reference)
// ─────────────────────────────────────────────

model PronunciationRulesMeta {
  id        Int      @id @default(1)
  intro     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PronunciationRuleTip {
  id        Int      @id @default(autoincrement())
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model PronunciationRuleSection {
  id        Int                       @id @default(autoincrement())
  slug      String                    @unique
  title     String
  summary   String
  sortOrder Int                       @default(0)
  points    PronunciationRulePoint[]
  examples  PronunciationRuleExample[]
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@index([sortOrder])
}

model PronunciationRulePoint {
  id          Int                    @id @default(autoincrement())
  sectionId   Int
  section     PronunciationRuleSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label       String?
  japanese    String?
  romaji      String?
  explanation String
  sortOrder   Int                    @default(0)

  @@index([sectionId, sortOrder])
}

model PronunciationRuleExample {
  id        Int                    @id @default(autoincrement())
  sectionId Int
  section   PronunciationRuleSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  japanese  String
  romaji    String
  meaning   String
  note      String?
  sortOrder Int                    @default(0)

  @@index([sectionId, sortOrder])
}

// ─────────────────────────────────────────────
// Daily listening
// ─────────────────────────────────────────────

model ListeningConfig {
  id          Int @id @default(1)
  goalMinutes Int @default(15)
}

model PodcastResource {
  id          Int      @id @default(autoincrement())
  externalKey String   @unique
  title       String
  description String
  url         String
  level       String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ListeningPreset {
  id          Int      @id @default(autoincrement())
  externalKey String   @unique
  label       String
  lessonFrom  Int
  lessonTo    Int
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// JLPT Đà Nẵng (static fallback)
// ─────────────────────────────────────────────

model JlptOrganizer {
  id               Int      @id @default(1)
  name             String
  shortName        String
  address          String
  phone            String
  email            String
  website          String
  announcementsUrl String
  updatedAt        DateTime @updatedAt
}

model JlptExamFeeInfo {
  id      Int    @id @default(1)
  formFee String
  examFee String
  note    String
}

model JlptExamBriefing {
  id   Int    @id @default(1)
  text String
}

model JlptExamSession {
  id                 Int               @id @default(autoincrement())
  externalKey        String            @unique
  label              String
  examDate           String
  registrationPeriod String
  status             JlptSessionStatus
  statusLabel        String
  announcementUrl    String?
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model JlptExamVenue {
  id        Int      @id @default(autoincrement())
  address   String
  district  String
  levels    String
  note      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JlptExamDaySlot {
  id        Int      @id @default(autoincrement())
  levels    String
  arriveAt  String
  startAt   String
  venue     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// JLPT roadmap
// ─────────────────────────────────────────────

model JlptRoadmapMeta {
  id               Int    @id @default(1)
  examScheduleNote String
}

model StudyTip {
  id        Int      @id @default(autoincrement())
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JlptRoadmapLevel {
  id           Int                      @id @default(autoincrement())
  externalKey  String                   @unique
  label        String
  badge        String
  color        String
  duration     String
  vocabTarget    String
  kanjiTarget    String
  grammarTarget  String
  vocabIncrement String                   @default("")
  kanjiIncrement String                   @default("")
  grammarIncrement String                 @default("")
  passScore      String
  summary      String
  sortOrder    Int                      @default(0)
  examSections JlptRoadmapExamSection[]
  materials    JlptRoadmapMaterial[]
  phases       JlptRoadmapPhase[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
}

model JlptRoadmapExamSection {
  id        Int              @id @default(autoincrement())
  levelId   Int
  level     JlptRoadmapLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  name      String
  points    Int
  time      String
  sortOrder Int              @default(0)

  @@index([levelId, sortOrder])
}

model JlptRoadmapMaterial {
  id            Int              @id @default(autoincrement())
  levelId       Int
  level         JlptRoadmapLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  title         String
  description   String
  scope         String
  inAppPath     String?
  inAppLabel    String?
  externalUrl   String?
  externalLabel String?
  sortOrder     Int              @default(0)

  @@index([levelId, sortOrder])
}

model JlptRoadmapPhase {
  id          Int               @id @default(autoincrement())
  levelId     Int
  level       JlptRoadmapLevel  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  externalKey String
  title       String
  subtitle    String
  sortOrder   Int               @default(0)
  tasks       JlptRoadmapTask[]

  @@unique([levelId, externalKey])
  @@index([levelId, sortOrder])
}

model JlptRoadmapTask {
  id            Int              @id @default(autoincrement())
  phaseId       Int
  phase         JlptRoadmapPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  externalKey   String
  text          String
  inAppPath     String?
  inAppLabel    String?
  externalUrl   String?
  externalLabel String?
  sortOrder     Int              @default(0)

  @@unique([phaseId, externalKey])
  @@index([phaseId, sortOrder])
}

// ─────────────────────────────────────────────
// Kanji
// ─────────────────────────────────────────────

model KanjiLesson {
  id           Int          @id @default(autoincrement())
  lessonNumber Int          @unique
  title        String?
  jlptLevel    JlptLevel?
  sortOrder    Int          @default(0)
  entries      KanjiEntry[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([jlptLevel, sortOrder])
}

model KanjiEntry {
  id           Int          @id @default(autoincrement())
  character    String
  hanViet      String?
  onyomi       String?
  kunyomi      String?
  meaningVi    String
  meaningEn    String?
  mnemonicJp   String?
  mnemonicVi   String?
  imageUrl     String?
  jlptLevel    JlptLevel?
  strokeCount  Int?
  frequency    Int?
  grade        Int?
  sortOrder    Int          @default(0)
  lessonId     Int
  lesson       KanjiLesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  vocabularies KanjiVocab[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([lessonId, sortOrder])
  @@index([character])
  @@index([jlptLevel])
}

model KanjiVocab {
  id           Int        @id @default(autoincrement())
  word         String
  reading      String
  meaningVi    String
  sortOrder    Int        @default(0)
  kanjiEntryId Int
  kanjiEntry   KanjiEntry @relation(fields: [kanjiEntryId], references: [id], onDelete: Cascade)

  @@index([kanjiEntryId, sortOrder])
}

// ─────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  passwordHash     String?
  googleId         String?        @unique
  role             Role           @default(USER)
  name             String?
  avatarUrl        String?
  nativeLanguage   String?        @default("vi")
  targetJlptLevel  JlptLevel?
  studyGoalMinutes Int?           @default(30)
  lastActiveAt     DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  srsCards       SrsCard[]
  examResults    ExamResult[]
  listeningLogs  ListeningLog[]
  studySessions  StudySession[]
  studyStreak    StudyStreak?
  dailyNotes     DailyNote[]
  dailyGoals     DailyGoal[]
  refreshTokens  RefreshToken[]
  subscription   Subscription?
  coachProfile   CoachProfile?
  learnerSessions CoachingSession[] @relation("LearnerSessions")
  payments       Payment[]
  reviewsGiven   CoachReview[]
  sentMessages   ChatMessage[]  @relation("SentMessages")
  notifications  Notification[]
  supportThread  SupportThread?
  supportMessages SupportMessage[] @relation("SupportMessages")
  createdLearnerChats LearnerChatRoom[]   @relation("CreatedLearnerChats")
  learnerChatMembers  LearnerChatMember[]
  learnerChatMessages LearnerChatMessage[] @relation("LearnerChatMessages")

  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// SRS — Spaced Repetition (SM-2)
// ─────────────────────────────────────────────

// Không còn snapshot fields (kana, kanji, meaning, lessonNumber).
// Dùng contentType + contentId để join sang đúng bảng khi cần hiển thị.
model SrsCard {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType ContentType
  contentId   Int

  // SM-2 algorithm fields
  easeFactor     Float     @default(2.5)
  interval       Int       @default(0)
  repetitions    Int       @default(0)
  nextReviewAt   DateTime?
  lastReviewedAt DateTime?

  // Statistics
  correctCount Int     @default(0)
  wrongCount   Int     @default(0)
  reviewStreak Int     @default(0)
  mastered     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contentType, contentId])
  @@index([userId, nextReviewAt])
  @@index([userId, contentType, mastered])
}

// ─────────────────────────────────────────────
// Progress & Exam
// ─────────────────────────────────────────────

model ExamResult {
  id           Int                 @id @default(autoincrement())
  userId       Int?
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  examId       String
  level        String
  title        String
  correctCount Int
  total        Int
  percent      Float
  passed       Boolean
  submittedAt  DateTime            @default(now())
  sections     ExamSectionResult[]

  @@index([userId, submittedAt])
  @@index([level])
}

model ExamSectionResult {
  id           Int        @id @default(autoincrement())
  examResultId Int
  examResult   ExamResult @relation(fields: [examResultId], references: [id], onDelete: Cascade)
  section      String
  correct      Int
  total        Int
  percent      Float

  @@index([examResultId])
}

model ListeningLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  seconds    Int      @default(0)
  lessonFrom Int?
  lessonTo   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model StudySession {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  seconds       Int      @default(0)
  cardsReviewed Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

// Streak tách riêng để tránh recompute từ StudySession mỗi lần hiển thị
model StudyStreak {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastStudyDate String?  // YYYY-MM-DD
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Reading
// ─────────────────────────────────────────────

model ReadingPassage {
  id           Int               @id @default(autoincrement())
  title        String
  content      String            @db.Text
  jlptLevel    JlptLevel?
  source       String?
  estimatedMin Int               @default(3)
  sortOrder    Int               @default(0)
  questions    ReadingQuestion[]
  attempts     ReadingAttempt[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([jlptLevel, sortOrder])
}

model ReadingQuestion {
  id          Int                     @id @default(autoincrement())
  passageId   Int
  passage     ReadingPassage          @relation(fields: [passageId], references: [id], onDelete: Cascade)
  question    String
  answer      String
  explanation String?
  sortOrder   Int                     @default(0)
  options     ReadingQuestionOption[]

  @@index([passageId, sortOrder])
}

model ReadingQuestionOption {
  id         Int             @id @default(autoincrement())
  questionId Int
  question   ReadingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  sortOrder  Int             @default(0)

  @@index([questionId, sortOrder])
}

model ReadingAttempt {
  id          Int            @id @default(autoincrement())
  userId      Int?
  passageId   Int
  passage     ReadingPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)
  correct     Int
  total       Int
  percent     Float
  submittedAt DateTime       @default(now())

  @@index([userId, submittedAt])
  @@index([passageId])
}

// ─────────────────────────────────────────────
// Dictation
// ─────────────────────────────────────────────

model DictationAttempt {
  id        Int        @id @default(autoincrement())
  userId    Int?
  vocabId   Int
  vocab     Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)
  userInput String
  correct   Boolean
  createdAt DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([vocabId])
}

// ─────────────────────────────────────────────
// Daily notes & goals
// ─────────────────────────────────────────────

model DailyNote {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

// Thay items Json bằng bảng riêng để query và update từng item
model DailyGoal {
  id        Int             @id @default(autoincrement())
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String          // YYYY-MM-DD
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     DailyGoalItem[]

  @@unique([userId, date])
  @@index([userId, date])
}

model DailyGoalItem {
  id        Int       @id @default(autoincrement())
  goalId    Int
  goal      DailyGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean   @default(false)
  sortOrder Int       @default(0)

  @@index([goalId, sortOrder])
}

// ─────────────────────────────────────────────
// Payment & Marketplace Enums
// ─────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  PAUSED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  PRO_ANNUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum SessionStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

// ─────────────────────────────────────────────
// Subscription (Learner trả tiền platform)
// ─────────────────────────────────────────────

model SubscriptionPlanConfig {
  id             Int              @id @default(autoincrement())
  plan           SubscriptionPlan @unique
  displayName    String
  priceUsdCents  Int
  intervalMonths Int              @default(1)
  trialDays      Int              @default(0)
  features       Json
  stripePriceId  String?
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Subscription {
  id                   Int                @id @default(autoincrement())
  userId               Int                @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  canceledAt           DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  payments             Payment[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}

// ─────────────────────────────────────────────
// Coach Profile (TEACHER user mở rộng)
// ─────────────────────────────────────────────

model CoachProfile {
  id              Int         @id @default(autoincrement())
  userId          Int         @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?     @db.Text
  languages       String[]
  specializations String[]
  hourlyRateUsd   Int
  currency        String      @default("USD")
  timezone        String      @default("Asia/Ho_Chi_Minh")
  isActive        Boolean     @default(false)
  isVerified      Boolean     @default(false)
  featuredUntil   DateTime?
  totalSessions   Int         @default(0)
  avgRating       Float?
  reviewCount     Int         @default(0)
  stripeAccountId String?     @unique
  payoutEnabled   Boolean     @default(false)
  availability    CoachAvailability[]
  sessions        CoachingSession[]
  reviews         CoachReview[]
  payouts         Payout[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([isActive, avgRating])
  @@index([isActive, hourlyRateUsd])
}

model CoachAvailability {
  id          Int          @id @default(autoincrement())
  coachId     Int
  coach       CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startHour   Int
  startMinute Int          @default(0)
  endHour     Int
  endMinute   Int          @default(0)

  @@index([coachId, dayOfWeek])
}

// ─────────────────────────────────────────────
// Coaching Session (Booking)
// ─────────────────────────────────────────────

model CoachingSession {
  id                 Int            @id @default(autoincrement())
  learnerId          Int
  learner            User           @relation("LearnerSessions", fields: [learnerId], references: [id])
  coachId            Int
  coach              CoachProfile   @relation(fields: [coachId], references: [id])
  status             SessionStatus  @default(PENDING)
  scheduledAt        DateTime
  durationMin        Int            @default(60)
  topic              String?
  notes              String?        @db.Text
  priceUsdCents      Int
  platformFeePercent Int            @default(20)
  payment            Payment?
  review             CoachReview?
  canceledAt         DateTime?
  canceledBy         String?
  cancelReason       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  messages           ChatMessage[]

  @@index([learnerId, scheduledAt])
  @@index([coachId, scheduledAt])
  @@index([status, scheduledAt])
}

// ─────────────────────────────────────────────
// Payment
// ─────────────────────────────────────────────

model Payment {
  id                    Int              @id @default(autoincrement())
  userId                Int
  user                  User             @relation(fields: [userId], references: [id])
  amountCents           Int
  currency              String           @default("USD")
  status                PaymentStatus    @default(PENDING)
  stripePaymentIntentId String?          @unique
  stripeChargeId        String?
  stripeReceiptUrl      String?
  subscriptionId        Int?
  subscription          Subscription?    @relation(fields: [subscriptionId], references: [id])
  sessionId             Int?             @unique
  session               CoachingSession? @relation(fields: [sessionId], references: [id])
  refundedAt            DateTime?
  refundAmountCents     Int?
  refundReason          String?
  metadata              Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

// ─────────────────────────────────────────────
// Payout (platform → Coach qua Stripe Connect)
// ─────────────────────────────────────────────

model Payout {
  id               Int          @id @default(autoincrement())
  coachId          Int
  coach            CoachProfile @relation(fields: [coachId], references: [id])
  amountCents      Int
  currency         String       @default("USD")
  status           PayoutStatus @default(PENDING)
  stripeTransferId String?      @unique
  stripePayoutId   String?
  periodStart      DateTime
  periodEnd        DateTime
  sessionCount     Int          @default(0)
  grossAmountCents Int
  feeAmountCents   Int
  processedAt      DateTime?
  failReason       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([coachId, status])
  @@index([periodStart, periodEnd])
}

// ─────────────────────────────────────────────
// Webhook Events (idempotency)
// ─────────────────────────────────────────────

model WebhookEvent {
  id           Int                @id @default(autoincrement())
  provider     String
  eventId      String             @unique
  eventType    String
  payload      Json
  status       WebhookEventStatus @default(RECEIVED)
  processedAt  DateTime?
  errorMessage String?
  retryCount   Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([eventType, status])
  @@index([provider, status, createdAt])
}

// ─────────────────────────────────────────────
// Coach Reviews
// ─────────────────────────────────────────────

model CoachReview {
  id        Int             @id @default(autoincrement())
  sessionId Int             @unique
  session   CoachingSession @relation(fields: [sessionId], references: [id])
  learnerId Int
  learner   User            @relation(fields: [learnerId], references: [id])
  coachId   Int
  coach     CoachProfile    @relation(fields: [coachId], references: [id])
  rating    Int
  comment   String?         @db.Text
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([coachId, rating])
}

// ─────────────────────────────────────────────
// Real-time: Chat & Notifications
// ─────────────────────────────────────────────

enum NotificationType {
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SESSION_CONFIRMED
  SESSION_CANCELED
  SESSION_REMINDER
  COACH_MESSAGE
  SUPPORT_MESSAGE
  GROUP_MESSAGE
  SYSTEM
}

enum LearnerChatRoomType {
  DIRECT
  GROUP
}

enum LearnerChatMemberRole {
  MEMBER
  ADMIN
}

model ChatMessage {
  id        Int             @id @default(autoincrement())
  sessionId Int
  session   CoachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId  Int
  sender    User            @relation("SentMessages", fields: [senderId], references: [id])
  content   String
  readAt    DateTime?
  createdAt DateTime        @default(now())

  @@index([sessionId, createdAt])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
}

model SupportThread {
  id            Int              @id @default(autoincrement())
  userId        Int              @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      SupportMessage[]
  lastMessageAt DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([lastMessageAt])
}

model SupportMessage {
  id        Int           @id @default(autoincrement())
  threadId  Int
  thread    SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  Int
  sender    User          @relation("SupportMessages", fields: [senderId], references: [id])
  content   String
  readAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([threadId, createdAt])
}

model LearnerChatRoom {
  id            Int                   @id @default(autoincrement())
  name          String?
  type          LearnerChatRoomType     @default(GROUP)
  createdById   Int
  createdBy     User                    @relation("CreatedLearnerChats", fields: [createdById], references: [id])
  members       LearnerChatMember[]
  messages      LearnerChatMessage[]
  lastMessageAt DateTime                @default(now())
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([lastMessageAt])
  @@index([type])
}

model LearnerChatMember {
  id       Int                   @id @default(autoincrement())
  roomId   Int
  room     LearnerChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   Int
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     LearnerChatMemberRole  @default(MEMBER)
  joinedAt DateTime               @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model LearnerChatMessage {
  id        Int             @id @default(autoincrement())
  roomId    Int
  room      LearnerChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  Int
  sender    User            @relation("LearnerChatMessages", fields: [senderId], references: [id])
  content   String
  readAt    DateTime?
  createdAt DateTime        @default(now())

  @@index([roomId, createdAt])
}
