{
  "name": "@edu/nihongo-services",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "seed:minna": "ts-node ../packages/prisma-nihongo/seed-minna.ts",
    "seed:vocab-images": "ts-node ../packages/prisma-nihongo/seed-vocab-images.ts",
    "seed:reference": "ts-node ../packages/prisma-nihongo/seed-reference.ts",
    "seed:kll": "ts-node ../packages/prisma-nihongo/seed-kll.ts",
    "format": "prettier --write \"api-gateway/**/*.ts\" \"content-service/**/*.ts\" \"exam-service/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start api-gateway",
    "start:dev": "node --watch -r tsconfig-paths/register -r ts-node/register api-gateway/src/main.ts",
    "start:content": "node --watch -r tsconfig-paths/register -r ts-node/register content-service/src/main.ts",
    "start:exam": "node --watch -r tsconfig-paths/register -r ts-node/register exam-service/src/main.ts",
    "build": "nest build api-gateway",
    "build:content": "nest build content-service",
    "build:exam": "nest build exam-service",
    "build:all": "npm run prisma:generate && nest build api-gateway && nest build content-service && nest build exam-service",
    "prisma:generate": "npm run generate -w @edu/prisma-nihongo && npm run generate -w @edu/prisma-english",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/api-gateway/src/main.js",
    "lint": "eslint \"{api-gateway,content-service,exam-service,payment-service,english-service,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@edu/vocab-images": "*",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.7.15",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^6.4.1",
    "@sentry/nestjs": "^10.62.0",
    "@sentry/profiling-node": "^10.62.0",
    "@types/cookie-parser": "^1.4.10",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "bcryptjs": "^3.0.3",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "mongoose": "^9.7.3",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prisma": "^6.4.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "yaml": "^2.9.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/api-gateway",
      "<rootDir>/content-service",
      "<rootDir>/exam-service",
      "<rootDir>/payment-service",
      "<rootDir>/english-service",
      "<rootDir>/../packages/nest-common",
      "<rootDir>/../packages/nest-contracts",
      "<rootDir>/../packages/nest-prisma"
    ],
    "moduleNameMapper": {
      "^@app/common$": "<rootDir>/../packages/nest-common/src",
      "^@app/common/(.*)$": "<rootDir>/../packages/nest-common/src/$1",
      "^@app/prisma$": "<rootDir>/../packages/nest-prisma/src",
      "^@app/prisma/(.*)$": "<rootDir>/../packages/nest-prisma/src/$1",
      "^@app/contracts$": "<rootDir>/../packages/nest-contracts/src",
      "^@app/contracts/(.*)$": "<rootDir>/../packages/nest-contracts/src/$1",
      "^@app/prisma-english$": "<rootDir>/../packages/nest-prisma-english/src",
      "^@app/prisma-english/(.*)$": "<rootDir>/../packages/nest-prisma-english/src/$1",
      "^@edu/prisma-english/client$": "<rootDir>/../packages/prisma-english/generated/client",
      "^@edu/prisma-english/client/(.*)$": "<rootDir>/../packages/prisma-english/generated/client/$1",
      "^@prisma/client$": "<rootDir>/../packages/prisma-nihongo/generated/client",
      "^@prisma/client/(.*)$": "<rootDir>/../packages/prisma-nihongo/generated/client/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "prisma": {
    "schema": "../packages/prisma-nihongo/schema.prisma",
    "seed": "ts-node ../packages/prisma-nihongo/seed.ts"
  }
}
