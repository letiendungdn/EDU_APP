# API backend URL (used by Next.js rewrites)
API_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
# Link trên nav (trình duyệt) khi english-web đang chạy
ENGLISH_APP_PUBLIC_URL=http://localhost:3001
# URL nội bộ để probe english-web (Docker: http://english-web:3001)
ENGLISH_APP_INTERNAL_URL=http://localhost:3001
# Google Sign-In (OAuth 2.0 Client ID — Web application)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Stripe publishable key (pk_test_... for test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# WebRTC signaling server (video call)
NEXT_PUBLIC_SIGNALING_URL=http://localhost:3002
